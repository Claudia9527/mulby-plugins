{
  "name": "mulby-showcase",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "mulby dev",
    "test": "npm run test:layout && npm run test:window-init && npm run test:child-window-size",
    "test:layout": "node scripts/test-window-log-layout.mjs",
    "test:window-init": "node scripts/test-child-window-init-listener.mjs",
    "test:child-window-size": "node scripts/test-child-window-create-size.mjs",
    "build": "npm run build:backend && npm run build:ui",
    "build:backend": "esbuild src/main.ts --bundle --platform=node --outfile=dist/main.js",
    "build:ui": "vite build",
    "pack": "mulby pack"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
